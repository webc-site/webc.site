@import "../../Btn/_.styl"

main.demo
  > b
    gap 20px
    display flex
    flex-direction column
    font-weight 400
    max-width 450px
    width 100%

    label
      align-items center
      color #666
      display flex
      font-size 14px
      gap 8px
      justify-content center

      input
        border 1px solid #d1d1d6
        border-radius 8px
        box-sizing border-box
        font-size 14px
        height 36px
        outline none
        padding 8px 12px
        text-align center
        width 80px

        &:focus
          border-color #0071e3

    .btn-group
      align-items center
      display flex
      flex-wrap wrap
      gap 16px
      justify-content center
