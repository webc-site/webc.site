body
  margin 0
  overflow hidden

c-webc-site
  display flex
  height 100dvh
  inset 0
  position absolute
  width 100%

  > c-vs
    > *
      max-width 1648px

    > c-nav
      align-self center
      width 100%

    > main
      display flex
      flex-direction column
      margin auto
      width 100%

    > main.doc
      align-items flex-start
      align-self center
      box-sizing border-box
      display flex
      flex-direction row
      gap 32px
      margin 0 auto
      padding 16px 0
      width 100%

      c-toc
        top 24px
        width 320px

        @media (max-width 1150px)
          width 260px

        @media (max-width 1000px)
          width 220px

        @media (max-width 900px)
          -webkit-backdrop-filter none
          backdrop-filter none
          background transparent
          border 0
          box-shadow none
          height 0
          padding 0
          width 0

      c-md
        box-sizing border-box
        flex 1
        margin 0 auto
        max-width 900px
        min-width 0

      @media (max-width 900px)
        padding 16px 20px

pre.err
  background-color #fff5f5
  border 1px solid #feb2b2
  border-radius 16px
  color #c53030
  font-size 14px
  margin 32px auto
  max-width 600px
  padding 24px
  white-space pre-wrap
  word-break break-all
