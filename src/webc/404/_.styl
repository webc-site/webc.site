c-404
  align-items center
  display flex
  flex-direction column
  margin auto
  justify-content center
  min-height 380px
  padding 64px 24px
  perspective 800px

  h1
    background linear-gradient(135deg, #0a84ff, #06c)
    font-size 20px
    font-weight 600
    margin 0 0 36px
    -webkit-background-clip text
    -webkit-text-fill-color transparent

  .Btn.Main
    margin 0 0 28px
    position relative
    z-index 10

  .ghost-area
    height 162px
    margin 0
    position relative
    transform translate(calc(var(--ex, 0) * 1px), calc(var(--ey, 0) * 1px))
    width 120px
    z-index 10000

    .ghost
      animation float 3s ease-in-out infinite
      cursor pointer
      display block
      height 100%
      position relative
      transform rotateX(calc(var(--rx, 0) * 1deg)) rotateY(calc(var(--ry, 0) * 1deg))
      transform-style preserve-3d
      transition transform 0.05s ease-out
      width 100%

      &:after
        background-image url('./svg/ghost.svg')
        background-repeat no-repeat
        background-size contain
        content ''
        height 100%
        left 0
        position absolute
        top 0
        transition filter 0.5s ease
        width 100%
        z-index 0

      &.angry
        animation float-angry 0.15s infinite, squeeze 0.6s ease-out

        &:after
          filter hue-rotate(150deg) saturate(2) drop-shadow(0 0 15px #ff453aa6)

        .eye
          background #ff3b3026
          border-color #ff3b3070
          box-shadow inset 0 2.5px 5px #0006, 0 0 15px #ff3b3050

        .eye:first-child
          border-radius 100% 20% 50% 50%

        .eye:last-child
          border-radius 20% 100% 50% 50%

        .ball
          box-shadow 0 0 15px #ff453abf, inset 0 -3px 4px #000a

          &:after
            opacity 1

        .pupil
          animation none
          background radial-gradient(circle at 35% 35%, #000 30%, #3a0008 100%)
          box-shadow 0 0 10px #000000d9
          scale 0.35

        .glare
          background #fff
          box-shadow 0 0 5px #fff
          scale 2.2

        .sparkle
          filter drop-shadow(0 0 3px #fffffff2)
          opacity 0.95
          scale 3

      &.furious
        .eye:before
          filter drop-shadow(0 1px 2px #ff3b30a1)
          opacity 1
          top calc(-16px + var(--by, 0) * 0.5 * 1px)

      .eyes
        display flex
        justify-content space-between
        left 50%
        position absolute
        top 33%
        transform translate(calc(var(--bx, 0) * 0.4 * 1px), calc(var(--by, 0) * 0.4 * 1px)) translateX(-50%)
        width 68px
        z-index 1

      .eye
        backdrop-filter blur(1px)
        background linear-gradient(135deg, #0f172a26 0, #0a84ff0d 100%)
        border 1px solid #0a84ff1f
        border-radius 50%
        box-shadow inset 0 2.5px 5px #0000002e, 0 1px 2px #fff6, 0 0 6px #0a84ff14
        height 28px
        position relative
        transition border-radius 0.3s ease, border-color 0.5s ease, box-shadow 0.5s ease, background 0.5s ease
        width 28px

        &:before
          background #ff453a
          content ''
          filter drop-shadow(0 1px 2px #ff453a66)
          height 8px
          opacity 0
          position absolute
          top calc(-24px + var(--by, 0) * 0.5 * 1px)
          transition all 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28)
          width 24px
          z-index 2

        &:first-child:before
          clip-path path('M 0 8 Q 8 2 24 1 L 24 6 Q 12 8 0 8 Z')
          left -2px
          transform rotate(15deg)

        &:last-child:before
          clip-path path('M 24 8 Q 16 2 0 1 L 0 6 Q 12 8 24 8 Z')
          right -2px
          transform rotate(-15deg)

      .wrap
        animation blink 2.5s infinite ease-in-out
        display block
        height 100%
        transform-origin center
        width 100%

      .ball
        align-items center
        background radial-gradient(circle at 35% 35%, #fff 30%, #f8fafc 70%, #e2e8f0 100%)
        border-radius 50%
        box-shadow 0 4px 10px #0a84ff38, inset 0 -3px 4px #0f172a0f
        display flex
        height 28px
        justify-content center
        left 0
        position absolute
        top 0
        transform translate(calc(var(--bx, 0) * 1px), calc(var(--by, 0) * 1px)) scale(var(--s, 1))
        transition transform 0.05s ease-out, box-shadow 0.5s ease
        width 28px

        &:after
          background radial-gradient(circle at 35% 35%, #ff453a 20%, #a70022 65%, #2a0008 100%)
          border-radius 50%
          content ''
          height 100%
          left 0
          opacity 0
          position absolute
          top 0
          transition opacity 0.5s ease
          width 100%
          z-index 1

      .pupil
        animation pupilPulse 3s ease-in-out infinite
        background radial-gradient(circle at 35% 35%, #1e293b 0, #0f172a 100%)
        border-radius 50%
        box-shadow 0 1.5px 3px #00000040
        height 14px
        position relative
        scale 1
        transform translate(calc(var(--px, 0) * 1px), calc(var(--py, 0) * 1px))
        transition transform 0.05s ease-out, scale 0.5s ease, background 0.5s ease, box-shadow 0.5s ease
        width 14px
        z-index 2

        .glare
          background #fff
          border-radius 50%
          box-shadow 0 0 1px #fffc
          height 5px
          left 3px
          position absolute
          top 3px
          transform translate(calc(var(--gx, 0) * 1px), calc(var(--gy, 0) * 1px))
          transition transform 0.05s ease-out
          width 5px

        .sparkle
          animation spinStar 4s linear infinite
          background #fff
          bottom 2.5px
          clip-path path('M 2 0 L 2.4 1.4 L 3.8 1.8 L 2.4 2.2 L 2 3.6 L 1.6 2.2 L 0.2 1.8 L 1.6 1.4 Z')
          height 4px
          opacity 0.7
          position absolute
          right 2.5px
          width 4px

    .shadow
      animation shadowPulse 3s ease-in-out infinite
      background radial-gradient(ellipse at center, #0a84ff80 0, #0a84ff00 70%)
      bottom -12px
      height 8px
      left 10%
      position absolute
      transition background 0.3s ease
      width 80%
      z-index 0

    .ghost.angry ~ .shadow
      background radial-gradient(ellipse at center, #ff453acc 0, #ff453a00 70%)

.burning-cursor
  &, *
    cursor url('./svg/fire-cursor.svg') 0 0, auto

.no-cursor
  &, *
    cursor none

.lasers
  height 100vh
  left 0
  pointer-events none
  position fixed
  top 0
  width 100vw
  z-index 10001

  line
    opacity 0

  #laser-burn
    opacity 0

  &.active
    #laser-l-outer, #laser-r-outer
      opacity 0.85

    #laser-l-inner, #laser-r-inner
      opacity 1

    #laser-burn
      opacity 1

.effects-canvas
  height 100vh
  left 0
  pointer-events none
  position fixed
  top 0
  width 100vw
  z-index 10001

@keyframes spinStar
  0%
    opacity 0.5
    transform rotate(0) scale(0.8)

  50%
    opacity 0.95
    transform rotate(180deg) scale(1.2)

  100%
    opacity 0.5
    transform rotate(360deg) scale(0.8)

@keyframes pupilPulse
  0%, 100%
    scale 1

  50%
    scale 1.15

@keyframes float
  0%, 100%
    translate 0 0

  50%
    translate 0 -12px

@keyframes float-angry
  0%, 100%
    translate 0 0

  25%
    translate -1.5px 1px

  50%
    translate 0 -1.5px

  75%
    translate 1.5px 0.5px

@keyframes shadowPulse
  0%, 100%
    opacity 0.8
    scale 1

  50%
    opacity 0.3
    scale 0.75

@keyframes blink
  0%, 84%, 100%
    transform scaleY(1)

  92%
    transform scaleY(0.1)

@keyframes squeeze
  0%, 100%
    scale 1 1

  25%
    scale 1.15 0.8

  50%
    scale 0.85 1.15

  75%
    scale 1.05 0.95
