.Input
  align-items center
  border-radius 22px
  box-sizing border-box
  cursor text
  display flex
  min-height 56px
  padding 16px 22px
  position relative
  transition padding 0.2s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.2s
  width 100%
  z-index 1
  --c #111

  &:has(input:not(:placeholder-shown))
    align-items flex-end
    padding 24px 22px 8px

    & input+label
      color #666
      font-size 12px
      font-variation-settings 'wght' 400
      letter-spacing 1px
      top 8px
      transform translateY(0)

  input
    background-color transparent
    border none
    box-sizing border-box
    color var(--c)
    font-family inherit
    font-size 17px
    margin 0
    outline none
    padding 0
    width 100%

    &:autofill, &:autofill:hover, &:autofill:focus
      transition background-color 999999s ease-in-out 0s
      -webkit-text-fill-color var(--c) !important

  label
    color #777
    font-size 17px
    left 22px
    letter-spacing 0
    pointer-events none
    position absolute
    top 50%
    transform translateY(-50%)
    transform-origin left center
    transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

  input, label
    font-weight 400

@media (max-width 600px)
  .Input
    min-height 52px
    padding 12px 24px

    &:has(input:not(:placeholder-shown))
      padding 20px 24px 4px

    label
      left 24px
