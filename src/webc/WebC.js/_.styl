c-webc-js
  display flex
  flex-direction column
  margin 0 auto
  width 100%

  .M
    display block
    padding 24px 0

  .L > b, .R > b
    display flex
    flex-direction column

  main.CodePre
    display block
    font-family c
    white-space pre-wrap
    word-break break-all
    font-size 15px

  h2.O
    font-size 18px
    margin 0 0 12px
    display flex
    align-items center
    gap 8px

    > c-edit, > c-code
      margin 0 6px 0 auto

@media (min-width 900px)
  c-webc-js
    box-sizing border-box
    align-items center
    max-width 1648px
    padding 0 24px 24px

    .M
      display flex
      flex-direction row
      gap 24px
      width 100%
      align-items start

    .L, .R
      flex 1
      min-width 0
      display flex
      flex-direction column
      gap 24px

@media (max-width 899px)
  c-webc-js
    .M
      display flex
      flex-direction column
      gap 24px

    .L, .R
      display flex
      flex-direction column
      margin 0 24px
