c-side
  overflow hidden
  height 100%
  left 0
  pointer-events none
  position fixed
  top 0
  visibility hidden
  width 100%
  z-index 11000

  .In
    background #fff
    box-sizing border-box
    height 100%
    max-width 85%
    pointer-events auto
    position absolute
    top 0
    width 280px

    c-vs
      display block
      height 100%

  &.right
    .In
      left auto
      right 0

  &:not(.open)
    &:not(.right):not(.top):not(.bottom)
      .In
        left 0
        transform translateX(-100%)

    &.right
      .In
        transform translateX(100%)

    &.top, &.bottom
      .In
        left 0
        width 100%
        max-width 100%
        height 280px
        max-height 85%

    &.top
      .In
        top 0
        transform translateY(-100%)

    &.bottom
      .In
        bottom 0
        transform translateY(100%)

  &.open, &.T
    visibility visible

    .In
      transition transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)

  &.open
    .In
      transform translate(0, 0)
