.Card
  background linear-gradient(180deg, #ffffffb3 0, #f5f5f74d 100%)
  border 1px solid #00000014
  border-radius 12px
  box-shadow 0 4px 12px #00000004, 0 1px 2px #00000003, inset 0 1px 0 #fff9
  box-sizing border-box
  color #222
  cursor pointer
  display flex
  flex-direction column
  font-size 14px
  gap 4px
  padding 14px 40px 14px 18px
  position relative
  text-align left
  transition border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease, font-variation-settings 0.25s ease
  user-select none
  width 100%

  &>h2
    color #555
    font-size 15px
    font-weight 400
    margin 0

  &:hover
    background linear-gradient(180deg, #ffffffd9 0, #f5f5f780 100%)
    border-color #0000002e
    box-shadow 0 6px 16px #0002, 0 2px 4px #00000005
    transform translateY(-1px)

    &::after
      opacity 0.6
      transform translateY(-50%) translateX(2px)

    &>h2
      color #111
      font-variation-settings 'wght' 400
      font-weight 400

    &>i
      color #444

  &:active
    box-shadow inset 0 0 6px #0000001a, 0 1px 2px #00000003
    transform scale(0.985)
    transition transform 0.1s ease

  &.A
    background linear-gradient(180deg, #0071e314 0, #0071e308 100%)
    border-color #0071e340
    box-shadow inset 0 1.5px 3px #0071e30a, 0 2px 4px #0071e303
    color #0071e3

    &>h2
      color #0071e3
      font-variation-settings 'wght' 400
      font-weight 400

    &>i
      color #0071e3cc

    &::after
      filter brightness(0) saturate(100%) invert(36%) sepia(85%) saturate(2333%) hue-rotate(200deg) brightness(94%) contrast(101%)
      opacity 1
      transform translateY(-50%) translateX(4px)

    &:hover
      background linear-gradient(180deg, #0071e31f 0, #0071e30d 100%)
      border-color #0071e359
      box-shadow inset 0 1.5px 3px #0071e30f, 0 6px 16px #0071e30d, 0 2px 4px #0071e305
      transform translateY(-1px)

      &::after
        transform translateY(-50%) translateX(5px)

    &:active
      box-shadow inset 0 0 8px #0071e324, 0 1px 2px #0071e303
      transform scale(0.985)
      transition transform 0.1s ease

  &::after
    background url('./svg/arrow.svg') center / contain no-repeat
    content ''
    filter none
    height 16px
    opacity 0
    position absolute
    right 16px
    top 50%
    transform translateY(-50%)
    transition opacity 0.25s ease, transform 0.25s ease, filter 0.25s ease
    width 16px

  &>i
    color #777
    font-weight 400
    font-size 12px
    font-style normal
    overflow hidden
