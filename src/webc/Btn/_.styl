.Btn, .BtnC
  border 1px solid transparent
  align-items center
  align-self center
  background-repeat no-repeat
  box-sizing border-box
  border-radius 22px
  color #444
  cursor pointer
  font-family inherit
  justify-content center
  text-decoration none
  transition all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  user-select none
  white-space nowrap

  &:hover
    color #000

  &:active
    transform scale(0.97)

  &::before
    background linear-gradient(135deg, #f5f5f5ee, #f5f5f526)

  &:hover::before
    background linear-gradient(135deg, #ffffff80, #ffffff30)
    border-color #9999
    box-shadow inset 0 0 6px #00000047

  &:active::before
    background linear-gradient(135deg, #ffffff14)
    box-shadow inset 0 1px 0 #fff9, inset 0 0 2px #0006

.Btn
  padding 12px 22px

.BtnC
  height 44px
  padding 0
  width 44px

  &::before
    border-color #0002

  .Ico
    background-position center
    background-repeat no-repeat
    background-size 20px
    display block
    filter opacity(0.8)
    height 100%
    transition transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)
    width 100%

  &:hover
    .Ico
      transform translateY(1px)

  &:active
    .Ico
      transform translateY(1px)

.Btn.Main
  color #fff
  transition color 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)

  &::before
    backdrop-filter none
    background linear-gradient(135deg, #0a84ff, #06c)
    border-color #0000002b
    box-shadow inset 0 1px 2px #0003, inset 0 -1px 2px #0000001a
    transition background 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1)

  &:hover
    color #fff

    &::before
      background radial-gradient(ellipse at center, #0a84ff 0, #0056cc 60%, #002b80 100%)
      box-shadow inset 0 1px 2px #0003, inset 0 -1px 2px #0000001a, inset 0 0 6px #00104073

  &:active
    transform scale(0.96)
    transition transform 0.1s ease

    &::before
      background linear-gradient(180deg, #04a, #06c)
      box-shadow inset 0 1px 2px #0003, inset 0 -1px 2px #0000001a, inset 0 0 4px #0010408c
      transition background 0.1s ease, box-shadow 0.1s ease, border-color 0.1s ease
