.Kv, .KvLi > a
  align-items center
  backdrop-filter blur(20px)
  background linear-gradient(180deg, #fff, #ebebf099)
  border 1px solid #00000014
  border-radius 8px
  box-shadow inset 0 0 0 1px #fff9, inset 0 0 8px #fffc, inset 0 0 4px #00000005
  color #555
  cursor pointer
  display flex
  overflow hidden
  text-decoration none
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

  &:hover
    background linear-gradient(180deg, #fff, #f0f0f5cc)
    border-color #00000029
    box-shadow inset 0 0 0 1px #ffffffb3, inset 0 0 10px #ffffffe6, inset 0 0 4px #00000003
    color #222

  &:active
    background linear-gradient(180deg, #f0f0f5f2, #dcdce1bf)
    box-shadow inset 0 0 8px #0000000a, inset 0 0 0 1px #fff6
    transform scale(0.98)

  b
    font-weight 500
    line-height 1
    padding 0.5em 0.8em

    &:first-child
      padding-right 0.6em

    &:last-child
      border-left 1px solid #0000000f
      padding-left 0.6em

.Kv, .KvLi
  display flex
  font-size 12px

.KvLi
  flex-wrap wrap
  gap 12px
