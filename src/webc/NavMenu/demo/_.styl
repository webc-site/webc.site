main.demo
  .hero
    .desc
      color #86868b
      font-size 16px
      line-height 1.5
      margin 0 auto

  .preview-section
    h2
      color #222
      font-size 20px
      margin-bottom 8px

    .sec-desc
      color #86868b
      font-size 14px
      line-height 1.4
      margin-bottom 20px

  .desktop-mockup
    background #f5f5f7
    border 1px solid #d2d2d7
    border-radius 12px
    box-shadow 0 8px 30px #00000014
    margin-bottom 24px
    overflow hidden

    & > c-nav
      background #fff
      border-bottom 1px solid #e5e5ea
      border-top none
      margin-bottom 0
      padding 16px 40px
      position relative
      top 0
      transform none

    .mockup-body
      background-image url('./svg/desktop-body.svg')
      background-position top center
      background-repeat no-repeat
      background-size 100% 100%
      display block
      height 220px

  .mobile-container
    display flex
    justify-content center
    padding 20px 0

  .mobile-mockup
    background #f5f5f7
    border 1px solid #d2d2d7
    border-radius 12px
    box-shadow 0 8px 30px #00000014
    display flex
    flex-direction column
    overflow hidden
    position relative
    width 320px

    & > c-nav
      background #fff
      border-bottom 1px solid #e5e5ea
      border-top none
      margin-bottom 0
      padding 16px
      position static
      transform none
      z-index 10

    .mockup-body
      background-image url('./svg/mobile-body.svg')
      background-position top center
      background-repeat no-repeat
      background-size 100% 100%
      display block
      height 300px

    c-nav-menu.force-mobile c-side
      height 100%
      position absolute !important
      width 100%
      z-index 99 !important

  c-nav-menu.force-desktop
    & c-side
      height auto !important
      pointer-events auto !important
      position static !important
      visibility visible !important
      width auto !important
      z-index auto !important

    & c-side .In
      box-shadow none !important
      height auto !important
      position static !important
      transform none !important
      width auto !important

    & c-side c-vs
      height auto !important

    & c-side
      display contents !important

    & c-side .In
      display contents !important

    & c-side c-vs
      display contents !important

    & c-side b
      padding 0 !important

    > button.BtnC
      display none !important

  c-nav-menu.force-mobile
    & c-side
      display block !important
      height 100% !important
      pointer-events none !important
      position fixed !important
      visibility hidden !important
      width 100% !important
      z-index 10000 !important

      &.open
        visibility visible !important

    & c-side .In
      background #fff !important
      box-shadow 2px 0 12px #0000001a !important
      box-sizing border-box !important
      display block !important
      height 100% !important
      max-width 85% !important
      pointer-events auto !important
      position absolute !important
      top 0 !important
      transition transform 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important
      width 280px !important

    & c-side c-vs
      display block !important
      height 100% !important

    & c-side b
      flex-direction column !important
      gap 8px !important
      padding 24px 16px !important

      > a.Card
        align-items stretch !important
        background linear-gradient(180deg, #ffffffb3 0, #f5f5f74d 100%) !important
        border 1px solid #00000014 !important
        border-radius 12px !important
        box-shadow 0 4px 12px #00000004, 0 1px 2px #00000003, inset 0 1px 0 #fff9 !important
        box-sizing border-box !important
        color #222 !important
        cursor pointer !important
        display flex !important
        flex-direction column !important
        font-size 14px !important
        font-variation-settings normal !important
        font-weight normal !important
        letter-spacing 0 !important
        padding 14px 40px 14px 18px !important
        position relative !important
        text-align left !important
        width 100% !important

        &::after
          content '' !important
          display block !important

        &:hover
          background linear-gradient(180deg, #ffffffd9 0, #f5f5f780 100%) !important
          border-color #0000002e !important
          box-shadow 0 6px 16px #0002, 0 2px 4px #00000005 !important
          transform translateY(-1px) !important

        &:active
          box-shadow inset 0 0 6px #0000001a, 0 1px 2px #00000003 !important
          transform scale(0.985) !important

        &.A
          background linear-gradient(180deg, #0071e314 0, #0071e308 100%) !important
          border-color #0071e340 !important
          box-shadow inset 0 1.5px 3px #0071e30a, 0 2px 4px #0071e303 !important
          color #0071e3 !important

          &::after
            display block !important
            opacity 1 !important

          &:hover
            background linear-gradient(180deg, #0071e31f 0, #0071e30d 100%) !important
            border-color #0071e359 !important
            box-shadow inset 0 1.5px 3px #0071e30f, 0 6px 16px #0071e30d, 0 2px 4px #0071e305 !important
            transform translateY(-1px) !important

    > button.BtnC
      display flex !important
