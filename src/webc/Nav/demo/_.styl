main.demo
  p
    color #666
    line-height 1.6
    margin-bottom 24px

  b.content
    display flex
    flex-direction column
    gap 16px
    width 100%

    &>b
      backdrop-filter blur(12px)
      border 1px solid transparent
      border-radius 16px
      box-shadow inset 0 1px 0 0 #fff6, 0 4px 12px #00000005
      display block
      height 80px
      transition transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1)

      &:hover
        box-shadow inset 0 1px 0 0 #fff9, 0 8px 24px #0000000f
        transform translateY(-2px)

  nav.Nav
    backdrop-filter blur(20px) saturate(190%)
    border 1px solid #0003
    border-radius 16px
    box-shadow inset 0 0 3px #0002
    padding 24px

    &.D
      top 64px

    a.logo
      color #222
      font-size 18px
      font-weight 600
      letter-spacing 0
      text-decoration none

    b
      display flex
      gap 20px
      margin-left auto

      a.item
        color #86868b
        font-size 14px
        font-weight 500
        text-decoration none
        transition color 0.2s ease

        &:hover
          color #222
