@import "../../Lg/_.styl"
@import "../../Btn/_.styl"

.demo
  &>b
    background #fff6
    border 1px solid #0002
    border-radius 16px
    box-shadow inset 0 1px 0 #fff9, 0 8px 32px #00000005
    display flex
    justify-content center
    padding 24px
    width 100%
    max-width 400px

  form
    width 100%

    h3
      color #222
      font-size 18px
      margin 0
      text-align center

    &>b
      display flex
      flex-direction column
      gap 6px

      label
        color #86868b
        display flex
        flex-direction column
        font-size 12px
        gap 4px

      input
        background #f5f5f5
        border-radius 10px
        font-size 14px
        padding 10px 14px
        width 100%

        &:focus
          background #fff
          box-shadow 0 0 0 4px #0071e326

    button
      width 100%
