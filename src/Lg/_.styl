$gap = 24px
$gap-mobile = 16px

@layer
  .Lg, .Btn, .BtnC, .Input
    display flex
    position relative
    z-index 1

    &::before
      backdrop-filter blur(2px) saturate(150%)
      border 1px solid #00000014
      border-radius inherit
      box-shadow inset 0 1px 0 #fff9
      box-sizing border-box
      content ''
      inset 0
      position absolute
      transition background 0.3s cubic-bezier(0.4, 0, 0.2, 1), backdrop-filter 0.3s cubic-bezier(0.4, 0, 0.2, 1)
      z-index -1

    &:hover::before
      backdrop-filter saturate(150%) url('./svg/glass.svg#h')

  .Lg, .Input
    &::before
      background linear-gradient(180deg, #ffffffec, #f5f5f7b0)

  main.Lg
    border-radius 24px
    padding $gap

    @media (max-width 800px)
      padding $gap-mobile
