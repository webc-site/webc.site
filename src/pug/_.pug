doctype html
html
  head
    meta(charset="UTF-8")
    title #{ title }
    meta(
      content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"
      name="viewport"
    )
    block head
  body
    style#W.
      c-t{visibility:hidden}
      body:before {
        content: "";
        position: fixed;
        top: 50%;
        left: 50%;
        margin: -32px;
        width: 64px;
        height: 64px;
        border: 6px solid #ccc;
        border-top-color: #888;
        border-radius: 50%;
        animation: I 1s linear infinite;
      }
      @keyframes I {
        to {
          transform: rotate(1turn);
        }
      }
    block body
