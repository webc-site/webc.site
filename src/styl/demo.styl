body
  background url('./svg/bg.svg') 0 0 / cover no-repeat fixed

main.demo
  align-items center
  box-sizing border-box
  display flex
  flex-direction column
  gap 16px
  margin auto
  max-width 960px
  padding 24px
  width fit-content

  @media (max-width 640px)
    padding 16px

  &.full-width, &:has(> c-webc-demo)
    padding 0
    width 100%
    max-width 100%
