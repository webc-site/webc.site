@import "../Box/_.styl"

dialog.Box.X>a.X
  align-items center
  backdrop-filter blur(16px)
  background #ffffffd9
  border none
  border-radius 50%
  bottom -64px
  box-shadow 0 8px 20px #0000000f, 0 0 0 1px #0000000a
  cursor pointer
  display flex
  height 32px
  justify-content center
  left 50%
  margin-left -16px
  position absolute
  transition transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease, opacity 0.3s ease
  width 32px
  z-index 1

  &::before
    background url('./svg/x.svg') center / 18px no-repeat
    content ''
    inset 0
    opacity 0.6
    pointer-events none
    position absolute
    transition opacity 0.3s ease

  &:hover
    backdrop-filter blur(16px)
    background #ffffffe0
    box-shadow 0 8px 20px #0000000f, 0 0 0 1px #0000000a, 0 0 3px inset #666
    transform rotate(90deg)

    &::before
      opacity 1

  &:active
    background #ffffffa6
    box-shadow 0 2px 4px #0000000f, 0 0 0 1px #0000000a, inset 0 2px 4px #0002

    &::before
      opacity 0.7

@media (max-height 900px)
  dialog.Box.X
    transform translateY(-32px)
